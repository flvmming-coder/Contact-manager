<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_surface"
    android:orientation="vertical"
    android:padding="12dp">

    <Button
        android:id="@+id/btnSettingsImport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_gradient_rect"
        android:text="@string/settings_import_contacts"
        android:textColor="#0F172A"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSettingsExport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_gradient_rect"
        android:text="@string/settings_export_vcf"
        android:textColor="#0F172A"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSettingsTheme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_gradient_rect"
        android:text="@string/settings_change_theme"
        android:textColor="#0F172A"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSettingsClearAll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_gradient_rect"
        android:text="@string/settings_clear_all"
        android:textColor="#0F172A"
        android:textStyle="bold" />

</LinearLayout>
