<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_top_header_gradient"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/headerTriggerArea"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imageHeaderIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_logo_ring"
                        android:contentDescription="@string/app_name"
                        android:padding="4dp"
                        app:srcCompat="@drawable/ic_contacts_header_white" />

                    <TextView
                        android:id="@+id/textAppTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/app_name"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/action_settings"
                        android:padding="6dp"
                        app:srcCompat="@drawable/ic_header_settings" />

                    <ImageButton
                        android:id="@+id/btnGoogleMode"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="2dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/action_google_mode"
                        android:padding="6dp"
                        app:srcCompat="@drawable/ic_header_google" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/textStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/stats_contacts_default"
                android:textColor="@color/stats_text"
                android:textSize="14sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/inputSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_search"
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <HorizontalScrollView
                android:id="@+id/groupScroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/groupContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <ImageButton
                android:id="@+id/btnGroupSettings"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_group_unselected"
                android:contentDescription="@string/group_manage_title"
                android:padding="7dp"
                app:srcCompat="@drawable/ic_header_settings"
                app:tint="@color/group_tab_text" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerContacts"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/textEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/empty_contacts"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnAddContact"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="end|bottom"
        android:layout_margin="4dp"
        android:background="@drawable/bg_fab_gradient_circle"
        android:contentDescription="@string/action_add_contact"
        android:elevation="8dp"
        android:padding="14dp"
        app:srcCompat="@drawable/ic_plus_white_24" />

    <LinearLayout
        android:id="@+id/selectionActionsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="4dp"
        android:background="@drawable/bg_dialog_surface"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/textSelectionCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/selection_count_default"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/selectionButtonsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSelectionGroup"
                style="@style/Widget.ContactManager.GradientButton.Small"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_assign_group" />

            <Button
                android:id="@+id/btnSelectionDelete"
                style="@style/Widget.ContactManager.GradientButton.Small"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/action_delete_selected" />

            <Button
                android:id="@+id/btnSelectionCancel"
                style="@style/Widget.ContactManager.GradientButton.Small"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/action_cancel_short" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
