<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_surface"
    android:orientation="vertical"
    android:padding="12dp">

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchLogs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/admin_logs_toggle" />

    <TextView
        android:id="@+id/textLogPathValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textVersionValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchColorEditor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/admin_color_editor_toggle" />

    <LinearLayout
        android:id="@+id/layoutRestartBypassCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/inputRestartBypassCode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_input"
            android:hint="@string/admin_restart_bypass_hint"
            android:inputType="numberPassword"
            android:maxLength="8"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <Button
            android:id="@+id/btnApplyRestartBypassCode"
            style="@style/Widget.ContactManager.GradientButton.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/admin_restart_bypass_apply" />
    </LinearLayout>

    <TextView
        android:id="@+id/textRestartBypassStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnCheckUpdates"
        style="@style/Widget.ContactManager.GradientButton.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/admin_check_updates" />

    <Button
        android:id="@+id/btnOpenLogs"
        style="@style/Widget.ContactManager.GradientButton.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/admin_open_logs" />

    <TextView
        android:id="@+id/textUpdateResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnDevelopersInfo"
        style="@style/Widget.ContactManager.GradientButton.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/admin_developers_button" />

</LinearLayout>
