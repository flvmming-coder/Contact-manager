<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_surface"
    android:orientation="vertical"
    android:padding="12dp">

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchLogs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/admin_logs_toggle" />

    <TextView
        android:id="@+id/textVersionValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textLogPathValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchColorEditor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/admin_color_editor_toggle" />

    <Button
        android:id="@+id/btnCheckUpdates"
        style="@style/Widget.ContactManager.GradientButton.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/admin_check_updates" />

    <TextView
        android:id="@+id/textUpdateResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnDevelopersInfo"
        style="@style/Widget.ContactManager.GradientButton.Small"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/admin_developers_button" />

</LinearLayout>
