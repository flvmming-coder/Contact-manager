<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchLogs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/admin_logs_toggle" />

    <TextView
        android:id="@+id/textVersionValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#0F172A"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textLogPathValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#475569"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnCheckUpdates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/admin_check_updates" />

    <TextView
        android:id="@+id/textUpdateResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#475569"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textDevelopersInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/admin_developers_info"
        android:textColor="#334155"
        android:textSize="12sp" />

</LinearLayout>
